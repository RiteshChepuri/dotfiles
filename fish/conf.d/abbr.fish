# Misclaneous
abbr dc "cd .."
abbr cls "clear"
abbr rmf "rm -rf"

# Brew Related
abbr bc "brew cleanup"
abbr bd "brew doctor"
abbr bi "brew install"
abbr bo "brew outdated"
abbr bu "brew update"
abbr bug "brew upgrade"

# Git related
abbr g "git"
abbr gi "git init"
abbr gs "git status"
abbr ga "git add ."
abbr gc "git commit"
abbr gr "git remote add origin"
abbr gpm "git push -u origin main"
abbr gl "git log"
abbr gcl "git clone"
abbr gbm "git branch -M main"
abbr gb "git branch"
abbr gsw "git switch"
abbr gp "git pull"
abbr gswc "git switch -c"
abbr gbd "git branch -d"
abbr gpa "git push -all"
abbr gf "git fetch"

# TMUX related
abbr ta "tmux a"
abbr tat "tmux attach -t"
abbr tk "tmux kill-server"
abbr td "tmux detach"
abbr tnd "tmux new -s (basename (pwd))"
abbr tn "tmux new -s"
abbr tl "tmux ls"
abbr te "exit"

# NVIM related
abbr v "nvim"
abbr v. "nvim +GoToFile"
abbr vf "nvim ~/.config/fish/config.fish"
abbr vt "nvim ~/.config/tmux/.tmux.conf"
abbr vn "nvim ~/.config/nvim"
abbr :GoToFile "nvim +GoToFile"

# NPM Related
abbr ni "npm install"
abbr ns "npm start"
abbr nr "npm run"

# Battery Health
abbr battery "upower -i /org/freedesktop/UPower/devices/battery_BAT0"

# Python related
abbr py python3
