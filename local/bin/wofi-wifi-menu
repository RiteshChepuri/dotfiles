#!/usr/bin/env bash

# Wi-Fi Selection & Connection Manager with Background Scanning, Notifications, and Signal Strength Priority

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

FIELDS="SSID,SECURITY,SIGNAL"
POSITION=0
YOFF=0
XOFF=0

if [ -r "$DIR/config" ]; then
    source "$DIR/config"
elif [ -r "$HOME/.config/wofi/wifi" ]; then
    source "$HOME/.config/wofi/wifi"
else
    echo "WARNING: Config file not found! Using default values."
fi

# Function to get Wi-Fi list, sorted by signal strength (strongest first)
get_sorted_wifi_list() {
    nmcli --fields "$FIELDS" device wifi list | sed '/^--/d' | sort -k3 -n -r
}

# Function to get current Wi-Fi connection status
get_connection_status() {
    nmcli -fields WIFI g
}

# Function to check if Wi-Fi is enabled
wifi_enabled() {
    [[ "$(get_connection_status)" =~ "enabled" ]]
}

# Function to enable auto-connect for known networks
enable_autoconnect() {
    local ssid="$1"
    nmcli con modify "$ssid" connection.autoconnect yes
}

# Function to send desktop notifications
send_notification() {
    local title="$1"
    local message="$2"
    notify-send "$title" "$message"
}

# Auto-reconnect function (runs in background)
auto_reconnect() {
    while true; do
        CURRSSID=$(LANGUAGE=C nmcli -t -f active,ssid dev wifi | awk -F: '$1 ~ /^yes/ {print $2}')
        if [[ -z "$CURRSSID" ]]; then
            send_notification "Wi-Fi Disconnected" "Attempting to reconnect..."
            KNOWN_SSIDS=$(nmcli -t -f NAME connection show | grep -v "lo")
            for SSID in $KNOWN_SSIDS; do
                nmcli con up "$SSID" && send_notification "Wi-Fi Connected" "Reconnected to $SSID" && break
            done
        fi
        sleep 10  # Check every 10 seconds
    done &
}

# Function to periodically scan for new networks (background process)
background_scan() {
    while true; do
        nmcli dev wifi rescan && echo "Scanning for new networks..." &>/dev/null
        sleep 2  # Rescan every 2 seconds
    done &
}

# Fetch and sort SSID list by signal strength
LIST=$(get_sorted_wifi_list)
RWIDTH=$(( $(echo "$LIST" | head -n 1 | awk '{print length($0)}') * 20 ))

LINENUMBERS=$(echo "$LIST" | wc -l)
LINENUM=$(( LINENUMBERS + 8 ))

KNOWNCON=$(nmcli connection show)
CONSTATE=$(get_connection_status)

CURRSSID=$(LANGUAGE=C nmcli -t -f active,ssid dev wifi | awk -F: '$1 ~ /^yes/ {print $2}')

# Limit menu size
if [ "$LINENUM" -gt 8 ] && wifi_enabled; then
    LINENUM=8
elif ! wifi_enabled; then
    LINENUM=1
fi

# Wi-Fi toggle text
TOGGLE="toggle on"
wifi_enabled && TOGGLE="toggle off"

# Menu options
OPTIONS="$TOGGLE\nrefresh\nmanual\n$LIST"

# Start background scanning
background_scan

# Start auto-reconnect in background
auto_reconnect

# Show menu
CHENTRY=$(echo -e "$OPTIONS" | uniq -u | wofi -i -d --prompt "Wi-Fi SSID: " --lines "$LINENUM" --location "$POSITION" --yoffset "$YOFF" --xoffset "$XOFF" --width "$RWIDTH")

# Exit if no selection
[ -z "$CHENTRY" ] && exit 0

CHSSID=$(echo "$CHENTRY" | sed 's/\s\{2,\}/\|/g' | awk -F "|" '{print $1}')

case "$CHENTRY" in
    "manual")
        MSSID=$(echo "Enter SSID (SSID,password)" | wofi -d "Manual Entry: " --lines 1)
        MPASS=$(echo "$MSSID" | awk -F "," '{print $2}')
        MSSID=$(echo "$MSSID" | awk -F "," '{print $1}')

        [ -z "$MSSID" ] && exit 0

        if [ -z "$MPASS" ]; then
            nmcli dev wifi con "$MSSID" && send_notification "Wi-Fi Connected" "Connected to $MSSID"
        else
            nmcli dev wifi con "$MSSID" password "$MPASS" && send_notification "Wi-Fi Connected" "Connected to $MSSID"
        fi
        enable_autoconnect "$MSSID"
        ;;

    "toggle on")
        nmcli radio wifi on && send_notification "Wi-Fi Enabled" "Wi-Fi is now enabled."
        ;;

    "toggle off")
        nmcli radio wifi off && send_notification "Wi-Fi Disabled" "Wi-Fi is now disabled."
        ;;

    "refresh")
        exec "$0" # Restart script to refresh SSID list
        ;;

    *)
        if [ "$CHSSID" = "*" ]; then
            CHSSID=$(echo "$CHENTRY" | sed 's/\s\{2,\}/\|/g' | awk -F "|" '{print $3}')
        fi

        ESCAPED_SSID=$(printf '%q' "$CHSSID")

        if echo "$KNOWNCON" | grep -q "$CHSSID"; then
            nmcli con up "$ESCAPED_SSID" && send_notification "Wi-Fi Connected" "Connected to $CHSSID"
        else
            if [[ "$CHENTRY" =~ "WPA2" ]] || [[ "$CHENTRY" =~ "WEP" ]]; then
                WIFIPASS=$(echo "Enter password (if saved, press Enter)" | wofi -P -d --prompt "Password: " --lines 1 --location "$POSITION" --yoffset "$YOFF" --xoffset "$XOFF" --width "$RWIDTH")
            fi
            nmcli dev wifi con "$ESCAPED_SSID" password "$WIFIPASS" && send_notification "Wi-Fi Connected" "Connected to $CHSSID"
        fi
        enable_autoconnect "$ESCAPED_SSID"
        ;;
esac
