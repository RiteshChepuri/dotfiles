#!/usr/bin/env bash

## Wofi Powermenu for Hyprland

# Configurable Variables
use_icons=true  # Set to false to disable icons
CONFIG="${WOFI_CONFIG:-$HOME/.config/wofi/config}"
STYLE="${WOFI_STYLE:-$HOME/.config/wofi/style.css}"

# Wofi Command
wofi_command="wofi --show dmenu \
    --conf ${CONFIG} --style ${STYLE} \
    --width=600 --height=310 \
    --cache-file=/dev/null \
    --hide-scroll --no-actions \
    --define=matching=fuzzy"

uptime=$(uptime -p | sed -e 's/up //g')

# Entries
if $use_icons; then
    shutdown="   Shutdown"
    reboot="   Reboot"
    lock="   Lock"
    suspend="   Sleep"
    logout="   Logout"
else
    shutdown="Shutdown"
    reboot="Reboot"
    lock="Lock"
    suspend="Sleep"
    logout="Logout"
fi

# Confirmation Prompt
confirm_action() {
    response=$(echo -e "No\nYes" | wofi --show dmenu --prompt "Are you sure?")
    [[ "$response" == "Yes" ]]
}

open_menu() {
    options="$lock\n$suspend\n$logout\n$reboot\n$shutdown"

    chosen=$(echo -e "$options" | timeout 10s $wofi_command --prompt "UP - $uptime")

    case $chosen in
        $shutdown)
            if confirm_action; then
                notify-send "System is shutting down..."
                sleep 2
                systemctl poweroff
            fi
            ;;
        $reboot)
            if confirm_action; then
                notify-send "Rebooting system..."
                sleep 2
                systemctl reboot
            fi
            ;;
        $lock) hyprlock ;;
        $suspend)
            battery_level=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null || echo 100)
            if [[ "$battery_level" -ge 5 ]]; then
                command -v mpc &>/dev/null && mpc -q pause
                command -v pulsemixer &>/dev/null && pulsemixer --mute
                ~/.config/hypr/scripts/lockscreen
                notify-send "System suspending..."
                sleep 2
                systemctl suspend
            else
                notify-send "Battery too low to suspend!" "Charge your device first."
            fi
            ;;
        $logout)
            if confirm_action; then
                notify-send "Logging out..."
                sleep 2
                hyprctl dispatch exit 0
            fi
            ;;
    esac
}

# Toggle Wofi Menu
pkill -x wofi || open_menu
