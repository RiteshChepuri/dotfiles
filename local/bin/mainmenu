#!/usr/bin/env bash

use_icons=true # Set to false to disable icons
CONFIG="$HOME/.config/wofi/config"
STYLE="$HOME/.config/wofi/style.css"

wofi_command="wofi --show dmenu
--conf ${CONFIG} --style ${STYLE} \
    --width=600 --height=250 \
    --cache-file=/dev/null \
    --hide-scroll --no-actions \
    --define=matching=fuzzy"

# Entries
if $use_icons; then
    powermenu="   Powermenu"
    wifi="    Wi-Fi"
    bluetooth="  Bluetooth"
else
    powermenu=" Powermenu"
    wifi="Wi-Fi"
    bluetooth=" Bluetooth"
fi

open_menu (){
    options="$powermenu\n$wifi\n$bluetooth"

    chosen="$(echo -e "$options" | $wofi_command --prompt )"
    case $chosen in
        $powermenu)
            if [[ "$?" == 0 ]]; then
                notify-send "Opening Powermenu "
                wofi-power-menu
            else
                exit
            fi
            ;;
        $wifi)
            if [[ "$?" == 0 ]]; then
                notify-send "Opening Wi-Fi menu"
                ~/.config/local/bin/wofi-wifi-menu
            else
                exit
            fi
            ;;
        $bluetooth)
            if [[ "$?" == 0 ]]; then
                notify-send "Opening Blueman-Manager"
                blueman-manager
            else
                exit
            fi
            ;;
    esac
}

if [[ ! `pidof wofi` ]]; then
    open_menu
else
    pkill wofi
fi
